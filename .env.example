APP_NAME=nen-tang-du-lieu-tin-tuc-vn
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO

# Database local mac dinh de trong de app tu chay bang SQLite
DATABASE_URL=

# Neu muon dung PostgreSQL, bo comment dong duoi va khoi dong `docker compose up -d postgres`
# DATABASE_URL=postgresql+psycopg://app_user:app_password@localhost:5432/news_ai_db

# SQLite du phong cho test hoac demo sieu nhanh
SQLITE_FALLBACK_URL=sqlite:///./data/app.db

RAW_STORAGE_PATH=./data/raw
PROCESSED_STORAGE_PATH=./data/processed
SOURCE_CONFIG_PATH=./config/sources.yml
USE_DEMO_ON_FAILURE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
CHAT_USE_OPENAI=true

# Phase D experimental: retrieval local-first cho news/policy
EXPERIMENTAL_RETRIEVAL_ENABLED=false
EXPERIMENTAL_RETRIEVAL_MODEL=experimental-local-sparse-v1
EXPERIMENTAL_RETRIEVAL_MIN_SCORE=0.025
EXPERIMENTAL_RETRIEVAL_LIMIT=6

STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://localhost:8000
